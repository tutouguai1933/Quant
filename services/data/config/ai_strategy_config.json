{
  "training": {
    "batch_size": 64,
    "learning_rate": 0.001,
    "epochs": 100,
    "validation_split": 0.2,
    "early_stopping_patience": 10,
    "exploration_rate": 0.1,
    "exploration_decay": 0.995
  },
  "model": {
