QUANT_RUNTIME_MODE=dry-run
QUANT_MARKET_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,DOGEUSDT

BINANCE_API_KEY=
BINANCE_API_SECRET=
QUANT_BINANCE_MARKET_BASE_URL=https://api.binance.com
QUANT_BINANCE_ACCOUNT_BASE_URL=https://api.binance.com
QUANT_BINANCE_TIMEOUT_SECONDS=10
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=127.0.0.1,localhost,api,web,freqtrade,mihomo

QUANT_FREQTRADE_API_USERNAME=Freqtrader
QUANT_FREQTRADE_API_PASSWORD=
QUANT_FREQTRADE_API_TIMEOUT_SECONDS=10

QUANT_ALLOW_LIVE_EXECUTION=false
QUANT_LIVE_ALLOWED_SYMBOLS=DOGEUSDT
QUANT_LIVE_MAX_STAKE_USDT=6
QUANT_LIVE_MAX_OPEN_TRADES=1

QUANT_ADMIN_USERNAME=admin
QUANT_ADMIN_PASSWORD=1933
QUANT_SESSION_TTL_SECONDS=604800

QUANT_QLIB_SESSION_ID=server

# Alert Push Configuration
# Telegram Bot Token (get from @BotFather)
QUANT_ALERT_TELEGRAM_TOKEN=
# Telegram Chat ID (your chat or group ID)
QUANT_ALERT_TELEGRAM_CHAT_ID=
# Webhook URL for custom alert integration
QUANT_ALERT_WEBHOOK_URL=
# Enable/disable alert push (default: true)
QUANT_ALERT_ENABLED=true

# VPN Switch Configuration
# Mihomo API URL (for switching proxy nodes)
QUANT_MIHOMO_API_URL=http://mihomo:9090
# Mihomo Proxy URL (for health check through proxy)
QUANT_MIHOMO_PROXY_URL=http://mihomo:7890
# Health check endpoint (default: Binance API ping)
QUANT_VPN_HEALTH_CHECK_URL=https://api.binance.com/api/v3/ping
# Health check timeout in seconds
QUANT_VPN_HEALTH_CHECK_TIMEOUT=10.0
# Health check interval in seconds (default: 60)
QUANT_VPN_HEALTH_CHECK_INTERVAL=60
# Whitelist IPs (comma-separated, must match Binance whitelist)
QUANT_VPN_WHITELIST_IPS=154.31.113.7,154.3.37.169,202.85.76.66
# Available VPN nodes (comma-separated)
QUANT_VPN_AVAILABLE_NODES=香港¹,香港²,香港³,香港⁴,日本¹,日本²,日本³,日本⁴,美国¹,美国²

# Auto Dispatch Configuration
# Enable/disable automatic signal dispatch (default: false)
QUANT_AUTO_DISPATCH_ENABLED=false
# Auto dispatch check interval in seconds (default: 300)
QUANT_AUTO_DISPATCH_INTERVAL=300
# Minimum score threshold for auto dispatch (default: 0.7)
QUANT_AUTO_DISPATCH_MIN_SCORE=0.7
# Maximum daily dispatch count (default: 5)
QUANT_AUTO_DISPATCH_MAX_DAILY=5
# Require dry_run_gate passed before dispatch (default: true)
QUANT_AUTO_DISPATCH_REQUIRE_DRY_RUN_GATE=true
# Require live_gate passed before dispatch (default: false)
QUANT_AUTO_DISPATCH_REQUIRE_LIVE_GATE=false
